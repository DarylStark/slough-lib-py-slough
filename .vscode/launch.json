    "version": "0.2.0",
    "configurations": [
        {
            "name": "CLI app - version",
            "type": "debugpy",
            "request": "launch",
            "module": "slough_cli_tool",
            "console": "integratedTerminal",
            "args": [
                "version"
            ]
        },
        {
            "name": "CLI app - config - env",
            "type": "debugpy",
            "request": "launch",
            "module": "slough_cli_tool",
            "console": "integratedTerminal",
            "args": [
                "config",
                "list"
            ]
        },
        {
            "name": "CLI app - project - init",
            "type": "debugpy",
            "request": "launch",
            "module": "slough_cli_tool",
            "console": "integratedTerminal",
            "args": [
                "--cfgfile",
                "test.yml",
                "project",
                "init",
                "--title",
                "testproject",
                "--version",
                "1.2.3",
                "--author-name",
                "Example User",
                "--author-email",
                "example@example.com",
                "--development-environment",
                "python-generic"
            ]
        },
        {
            "name": "CLI app - config - convert - yaml",
            "type": "debugpy",
            "request": "launch",
            "module": "slough_cli_tool",
            "console": "integratedTerminal",
            "args": [
                "config",
                "convert",
                "yml"
            ]
        },
        {
            "name": "CLI app - config - convert - json",
            "type": "debugpy",
            "request": "launch",
            "module": "slough_cli_tool",
            "console": "integratedTerminal",
            "args": [
                "config",
                "convert",
                "json"
            ]
        },
        {
            "name": "CLI app - config - generate-schema",
            "type": "debugpy",
            "request": "launch",
            "module": "slough_cli_tool",
            "console": "integratedTerminal",
            "args": [
                "config",
                "generate-schema"
            ]
        },
        {
            "name": "CLI app - dev-container - generate-config",
            "type": "debugpy",
            "request": "launch",
            "module": "slough_cli_tool",
            "console": "integratedTerminal",
            "args": [
                "dev-container",
                "generate-config"
            ]
        },
        {
            "name": "CLI app - container - tags - list",
            "type": "debugpy",
            "request": "launch",
            "module": "slough_cli_tool",
            "console": "integratedTerminal",
            "args": [
                "container",
                "tags",
                "list"
            ]
        }
    ]
}