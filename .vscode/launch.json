    "version": "0.2.0",
    "configurations": [
        {
            "name": "CLI app - config - show (default)",
            "type": "debugpy",
            "request": "launch",
            "module": "slough_cli_tool",
            "console": "integratedTerminal",
            "args": [
                "config",
                "show"
            ]
        },
        {
            "name": "CLI app - config - show (as YAML)",
            "type": "debugpy",
            "request": "launch",
            "module": "slough_cli_tool",
            "console": "integratedTerminal",
            "args": [
                "config",
                "show",
                "--output",
                "yaml"
            ]
        },
        {
            "name": "CLI app - config - show (as JSON)",
            "type": "debugpy",
            "request": "launch",
            "module": "slough_cli_tool",
            "console": "integratedTerminal",
            "args": [
                "config",
                "show",
                "--output",
                "json"
            ]
        },
        {
            "name": "CLI app - config - show (as ENVVARS)",
            "type": "debugpy",
            "request": "launch",
            "module": "slough_cli_tool",
            "console": "integratedTerminal",
            "args": [
                "config",
                "show",
                "--output",
                "envvars"
            ]
        },
        {
            "name": "CLI app - config - init",
            "type": "debugpy",
            "request": "launch",
            "module": "slough_cli_tool",
            "console": "integratedTerminal",
            "args": [
                "config",
                "init"
            ]
        }
    ]
}